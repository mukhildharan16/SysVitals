# Cloudflare Tunnel is the TLS edge. Keep this HTTP origin reachable only from
# cloudflared inside this WSL distribution.
:8080 {
	bind 127.0.0.1
	encode zstd gzip

	@backend path /api/* /health
	reverse_proxy @backend 127.0.0.1:8000

	root * /opt/sysvitals/frontend
	file_server

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format console
	}
}
