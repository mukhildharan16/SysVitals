{$DOMAIN} {
	encode zstd gzip

	@backend path /api/* /health
	handle @backend {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv
		file_server
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format console
	}
}
