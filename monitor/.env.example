# SysVitals Telemetry Monitor Configuration
# Copy this to .env in this folder (or parent folder) and fill in the values.

# The base URL of the running FastAPI server (e.g. http://127.0.0.1:8000 or your remote URL)
TW_SERVER_URL="http://127.0.0.1:8000"

# The unique secret key for this device, generated after registering it on the dashboard
TW_DEVICE_SECRET="sv_xxxxxx"

# Friendly hostname identifier for this machine (optional, defaults to native PC hostname)
TW_HOSTNAME="My-Legion-Laptop"

# Upload frequency interval in seconds (default is 0.5s for 2Hz telemetry updates)
TW_INTERVAL_SECONDS=0.5
