# Shared SysVitals configuration. Copy to .env and edit for your deployment.
DOMAIN=mydomain.com
BIND_ADDRESS=0.0.0.0
HTTP_PORT=80
HTTPS_PORT=443

# SQLite location inside the backend container.
DATABASE_PATH=/app/data/sysvitals.db

# Monitor configuration.
TW_SERVER_URL=https://mydomain.com
TW_DEVICE_SECRET=
TW_INTERVAL_SECONDS=0.5
